<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Avatar -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chat_avatar"
            android:tint="#BB86FC" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvChatTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private Chat"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encrypted · Local Only"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Logout/Lock button -->
        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_lock"
            android:tint="#888888"
            android:contentDescription="Lock" />
    </LinearLayout>

    <!-- Messages List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_attach"
            android:tint="#888888"
            android:contentDescription="Attach" />

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/input_bg_chat"
            android:hint="Message..."
            android:textColorHint="#555555"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine"
            android:maxLines="4" />

        <ImageButton
            android:id="@+id/btnSendMessage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_send_bg"
            android:src="@drawable/ic_send"
            android:tint="#FFFFFF"
            android:contentDescription="Send" />
    </LinearLayout>
</LinearLayout>
